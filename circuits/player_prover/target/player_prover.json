{"noir_version":"1.0.0-beta.6+e796dfd67726cbc28eb9991782533b211025928d","hash":"4649140175168468047","abi":{"parameters":[{"name":"run_id","type":{"kind":"field"},"visibility":"public"},{"name":"player_id","type":{"kind":"field"},"visibility":"public"},{"name":"gems_earned","type":{"kind":"field"},"visibility":"public"},{"name":"timestamp","type":{"kind":"field"},"visibility":"public"},{"name":"base_gems","type":{"kind":"field"},"visibility":"private"},{"name":"synergy_bonus","type":{"kind":"field"},"visibility":"private"},{"name":"deep_mine_mult","type":{"kind":"field"},"visibility":"private"},{"name":"pet_count","type":{"kind":"field"},"visibility":"private"},{"name":"boost_multiplier","type":{"kind":"field"},"visibility":"private"},{"name":"item_multiplier","type":{"kind":"field"},"visibility":"private"},{"name":"mining_mode","type":{"kind":"field"},"visibility":"private"},{"name":"random_outcome","type":{"kind":"field"},"visibility":"private"},{"name":"has_gem_paws","type":{"kind":"field"},"visibility":"private"}],"return_type":null,"error_types":{"2920182694213909827":{"error_kind":"string","string":"attempt to subtract with overflow"},"5019202896831570965":{"error_kind":"string","string":"attempt to add with overflow"},"7233212735005103307":{"error_kind":"string","string":"attempt to multiply with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"fn main(\n    run_id: pub Field,\n    player_id: pub Field,\n    gems_earned: pub Field,\n    timestamp: pub Field,\n\n    base_gems: Field,\n    synergy_bonus: Field,\n    deep_mine_mult: Field,\n    pet_count: Field,\n    boost_multiplier: Field,\n    item_multiplier: Field,\n    mining_mode: Field,\n    random_outcome: Field,\n    has_gem_paws: Field,\n) {\n    let bg = base_gems as u64;\n    let pc = pet_count as u64;\n    let sb = synergy_bonus as u64;\n    let dm = deep_mine_mult as u64;\n    let boost = boost_multiplier as u64;\n    let item = item_multiplier as u64;\n    let mode = mining_mode as u64;\n    let outcome = random_outcome as u64;\n    let gp = has_gem_paws as u64;\n    let p: u64 = 100;\n\n    let step1 = bg * pc * (p + (pc - 1) * sb) / p;\n\n    let step2 = if mode == 1 {\n        step1 * dm / p\n    } else {\n        step1\n    };\n\n    let expected: u64 = if outcome == 0 {\n        step2 * (p + boost) * (p + item) / (p * p)\n    } else if gp == 1 {\n        let potential = step2 * (p + boost) * (p + item) / (p * p);\n        potential / 10\n    } else {\n        0\n    };\n\n    assert(expected as Field == gems_earned);\n}\n","path":"/Users/morganpage/Documents/VSCODE/TELEGRAM/TON/outmine-server/circuits/automine_player_prover/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient","directive_invert"]}